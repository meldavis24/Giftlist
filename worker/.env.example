SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Same VAPID key pair used by the web app (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Used to build the link inside push notifications
APP_URL=http://localhost:3000

# Optional: get one from your Apify account (Settings -> Integrations -> API tokens).
# Without it, price checks fall back to free direct-fetch only, which can't read
# bot-protected sites (Amazon, Etsy, etc.). WITH it, every check on a blocked site
# costs a few cents via Apify -- see README before picking CHECK_INTERVAL_MINUTES,
# since a short interval multiplied across many items adds up fast.
APIFY_API_TOKEN=

# How often to re-check prices when run as a long-lived process (not used with --once).
# Once APIFY_API_TOKEN is set, prefer something like 720 (twice a day) over the
# default 60 -- hourly checks on Apify-backed items get expensive quickly.
CHECK_INTERVAL_MINUTES=60

# Delay between checking each item, to be polite to retailer sites
FETCH_DELAY_MS=1500
