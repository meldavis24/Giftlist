NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Optional: get one from your Apify account (Settings -> Integrations -> API tokens).
# Without it, price checks fall back to free direct-fetch only, which can't read
# bot-protected sites (Amazon, Etsy, etc.) -- see README for what this costs per check.
APIFY_API_TOKEN=
